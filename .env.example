# ============================================================
# S3 / object storage credentials (for downloading raw videos)
# Copy this file to .env and fill in your own values:
#   cp .env.example .env
# The .env file is git-ignored and must never be committed.
# ============================================================

# S3-compatible endpoint URL (e.g. https://s3.eu-central-1.amazonaws.com
# or a self-hosted MinIO/Ceph endpoint)
S3_ENDPOINT_URL=

# Access credentials
S3_AWS_ACCESS_KEY_ID=
S3_AWS_SECRET_ACCESS_KEY=

# Bucket that stores the raw recordings
S3_BUCKET_NAME=

# Optional common prefix prepended to every object key
# (leave empty if your objects live at the bucket root)
S3_BASE_PREFIX=